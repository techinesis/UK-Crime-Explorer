# Mac system files
.DS_Store

# Python cache files
__pycache__/
*.pyc

# Virtual environments
.env
.venv/
venv/

# Jupyter notebook checkpoints
.ipynb_checkpoints/

# Large data files - do not upload to GitHub
data/london_crime_by_lsoa.csv
data/lsoa-data
data/borough-data
data/ward-data
outputs/crime_aggregated_for_app.csv

# Per-filter colored GeoJSON cache generated at runtime
static/colored/*.geojson
!static/colored/.gitkeep

.cache

# --- Full-stack rewrite (React + FastAPI) ---
# NOTE: data/crime_snapshot.parquet IS committed — it is the production data
# source on Vercel (the 890 MB raw CSV above is not deployable). It is small (~2 MB).
# Frontend: node + build artifacts
frontend/node_modules/
frontend/dist/
frontend/.vite/
# Generated static boundaries (rebuilt from data/*.geojson by prepare-static.mjs)
frontend/public/boundaries/
# Forecast: the committed source is forecast_dashboard_long.json.gz (~3 MB); the raw
# .json below is regenerated from it at build time by prepare-forecast.mjs, so ignore it.
frontend/public/forecast_dashboard_long.json
# Vite builds the SPA here (repo-root public/) for Vercel's FastAPI static serving
/public/
# Python venvs anywhere in the tree
backend/.venv/
# Vercel local
.vercel/
